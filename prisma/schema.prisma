generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectType {
  scripted
  unscripted
  animation
  limited_series
  format
  international
  acquisition
  co_production
}

enum ProjectStatus {
  sold
  in_development
  pilot_order
  series_order
  airing
  renewed
  canceled
  passed
  stale
  unknown
}

enum BuyerType {
  broadcast
  cable
  streamer
  studio
  distributor
}

enum CompanyType {
  studio
  production_company
  distributor
  agency
  management_company
}

enum PersonRole {
  writer
  creator
  showrunner
  producer
  actor
  executive
  director
}

enum UserRole {
  admin
  editor
  viewer
}

enum CurrentShowSeasonType {
  new_series
  returning_series
  limited_series
  special
  finale
}

enum DuplicateStatus {
  not_duplicate
  possible_duplicate
  confirmed_duplicate
  merged
}

enum SavedViewVisibility {
  private
  team
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum SourceCoverageType {
  trade
  official_press
  calendar
  manual_csv
  search_api
  rss
}

enum MissingDataSeverity {
  low
  medium
  high
}

enum WatchlistType {
  buyer
  company
  person
  genre
  keyword
  source
  status
  country
}

enum AlertType {
  new_match
  status_change
  premiere_update
  low_confidence
  missing_data
  duplicate_detected
}

enum JobRunStatus {
  queued
  running
  completed
  failed
  canceled
}

enum FeedbackType {
  bug
  data_issue
  feature_request
  confusion
  other
}

enum FeedbackStatus {
  new
  triaged
  in_progress
  resolved
  dismissed
}

enum FeedbackPriority {
  low
  medium
  high
}

model Project {
  id                    String         @id @default(cuid())
  title                 String
  aliases               String?
  type                  ProjectType
  status                ProjectStatus
  logline               String?
  genre                 String?
  format                String?
  source_material       String?
  buyerId               String?
  buyer                 Buyer?         @relation(fields: [buyerId], references: [id])
  networkOrPlatform     String?
  studioId              String?
  studio                Company?       @relation("StudioProjects", fields: [studioId], references: [id])
  productionCompanies   Company[]      @relation("ProjectProductionCompanies")
  people                Person[]       @relation("ProjectPeople")
  countryOfOrigin       String?
  isInternational       Boolean        @default(false)
  isCoProduction        Boolean        @default(false)
  isAcquisition         Boolean        @default(false)
  acquisitionDetails    String?
  announcementDate      DateTime?
  premiereDate          DateTime?
  lastUpdateDate        DateTime?
  sourceUrl             String?
  sourcePublication     String?
  confidenceScore       Float          @default(0.7)
  confidenceLevel       ConfidenceLevel @default(medium)
  confidenceReasons     String?
  duplicateGroupId      String?
  duplicateConfidence   Float?
  possibleDuplicateOfId String?
  duplicateStatus       DuplicateStatus @default(not_duplicate)
  tags                  String?
  archivedAt            DateTime?
  needsReview           Boolean        @default(false)
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  relationships         Relationship[]
  linkedArticles        Article[]      @relation("LinkedProjectArticles")

  @@index([title])
  @@index([buyerId])
  @@index([studioId])
  @@index([status])
  @@index([genre])
  @@index([countryOfOrigin])
  @@index([announcementDate])
  @@index([premiereDate])
  @@index([confidenceLevel])
  @@index([duplicateGroupId])
  @@index([duplicateStatus])
  @@index([archivedAt])
}

model CurrentShow {
  id                    String   @id @default(cuid())
  title                 String
  aliases               String?
  networkOrPlatform     String
  premiereDate          DateTime?
  finaleDate            DateTime?
  seasonNumber          Int?
  episodeCount          Int?
  status                String
  genre                 String?
  studio                String?
  productionCompanies   String?
  country               String?
  sourceType            String?
  sourceReliability     String?
  seasonType            CurrentShowSeasonType?
  premiereTime          String?
  episodeTitle          String?
  episodeNumber         Int?
  airPattern            String?
  verifiedAt            DateTime?
  needsVerification     Boolean  @default(false)
  sourceUrl             String?
  confidenceScore       Float    @default(0.68)
  confidenceLevel       ConfidenceLevel @default(medium)
  confidenceReasons     String?
  duplicateGroupId      String?
  duplicateConfidence   Float?
  possibleDuplicateOfId String?
  duplicateStatus       DuplicateStatus @default(not_duplicate)
  tags                  String?
  archivedAt            DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  linkedArticles        Article[] @relation("LinkedShowArticles")

  @@index([premiereDate])
  @@index([finaleDate])
  @@index([networkOrPlatform])
  @@index([status])
  @@index([genre])
  @@index([seasonType])
  @@index([needsVerification])
  @@index([verifiedAt])
  @@index([confidenceLevel])
  @@index([duplicateGroupId])
  @@index([duplicateStatus])
  @@index([archivedAt])
}

model CurrentTvSource {
  id                String   @id @default(cuid())
  name              String
  sourceType        String
  url               String?
  category          String
  enabled           Boolean  @default(true)
  sourceReliability String?
  lastChecked       DateTime?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([name])
  @@index([sourceType])
  @@index([category])
  @@index([enabled])
}

model Buyer {
  id            String         @id @default(cuid())
  name          String         @unique
  aliases       String?
  type          BuyerType
  parentCompany String?
  duplicateGroupId      String?
  duplicateConfidence   Float?
  possibleDuplicateOfId String?
  duplicateStatus       DuplicateStatus @default(not_duplicate)
  tags            String?
  archivedAt      DateTime?
  notes         String?
  projects      Project[]
  relationships Relationship[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([type])
  @@index([parentCompany])
  @@index([duplicateGroupId])
  @@index([duplicateStatus])
  @@index([archivedAt])
}

model Company {
  id                     String         @id @default(cuid())
  name                   String         @unique
  aliases                String?
  type                   CompanyType
  duplicateGroupId       String?
  duplicateConfidence    Float?
  possibleDuplicateOfId  String?
  duplicateStatus        DuplicateStatus @default(not_duplicate)
  tags                   String?
  archivedAt             DateTime?
  notes                  String?
  studioProjects         Project[]      @relation("StudioProjects")
  productionProjects     Project[]      @relation("ProjectProductionCompanies")
  relationships          Relationship[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([type])
  @@index([duplicateGroupId])
  @@index([duplicateStatus])
  @@index([archivedAt])
}

model Person {
  id            String         @id @default(cuid())
  name          String         @unique
  aliases       String?
  role          PersonRole
  company       String?
  reps          String?
  duplicateGroupId      String?
  duplicateConfidence   Float?
  possibleDuplicateOfId String?
  duplicateStatus       DuplicateStatus @default(not_duplicate)
  tags         String?
  archivedAt   DateTime?
  notes         String?
  projects      Project[]      @relation("ProjectPeople")
  relationships Relationship[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([role])
  @@index([company])
  @@index([duplicateGroupId])
  @@index([duplicateStatus])
  @@index([archivedAt])
}

model Article {
  id                    String       @id @default(cuid())
  url                   String       @unique
  publication           String?
  headline              String
  aliases               String?
  publishedDate         DateTime?
  summary               String?
  rawText               String?
  rawHtml               String?
  extractedText         String?
  extractedExcerpt      String?
  extractionMethod      String?
  bodyFetchStatus       String?
  bodyFetchError        String?
  bodyFetchedAt         DateTime?
  robotsAllowed         Boolean?
  paywallLikely         Boolean       @default(false)
  sourceReliability     String?
  sourceType            String?
  ingestionSource       String?
  needsReview           Boolean      @default(true)
  extractionStatus      String       @default("Needs Review")
  extractionMode        String?
  suspectedCategory     String?
  linkedProjectId       String?
  linkedProject         Project?     @relation("LinkedProjectArticles", fields: [linkedProjectId], references: [id])
  linkedShowId          String?
  linkedShow            CurrentShow? @relation("LinkedShowArticles", fields: [linkedShowId], references: [id])
  confidenceScore       Float?
  relevanceScore        Float?
  relevanceBand         String?
  relevanceReasons      String?
  relevanceDecision     String?
  extractionConfidence  Float?
  extractionSource      String?
  bodyAvailable         Boolean      @default(false)
  extractedProjectTitle String?
  extractedFormat       String?
  extractedGenre        String?
  extractedSourceMaterial String?
  extractedStatus       String?
  extractedLogline      String?
  extractedBuyer        String?
  extractedStudio       String?
  extractedCompanies    String?
  extractedPeople       String?
  extractedCountry      String?
  extractedIsAcquisition Boolean?
  extractedIsCoProduction Boolean?
  extractedIsInternational Boolean?
  extractedPremiereDate DateTime?
  extractedAnnouncementDate DateTime?
  extractedRelationships String?
  extractedFieldsNeedingReview String?
  extractedDeduplicationNotes String?
  extractedStructuredDataJson Json?
  aiExtractionError     String?
  duplicateGroupId      String?
  duplicateConfidence   Float?
  possibleDuplicateOfId String?
  duplicateStatus       DuplicateStatus @default(not_duplicate)
  tags                  String?
  archivedAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([publication])
  @@index([publishedDate])
  @@index([needsReview])
  @@index([ingestionSource])
  @@index([bodyFetchStatus])
  @@index([sourceReliability])
  @@index([extractionSource])
  @@index([relevanceBand])
  @@index([relevanceDecision])
  @@index([extractionStatus])
  @@index([extractionMode])
  @@index([suspectedCategory])
  @@index([linkedProjectId])
  @@index([linkedShowId])
  @@index([duplicateGroupId])
  @@index([duplicateStatus])
  @@index([archivedAt])
}

model RssFeed {
  id              String   @id @default(cuid())
  publicationName String
  feedUrl         String   @unique
  category        String
  enabled         Boolean  @default(true)
  lastChecked     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([publicationName])
  @@index([category])
  @@index([enabled])
  @@index([lastChecked])
}

model IngestionRun {
  id           String   @id @default(cuid())
  sourceType   String
  sourceName   String?
  status       String
  itemsFetched Int      @default(0)
  itemsSaved   Int      @default(0)
  itemsSkipped Int      @default(0)
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  notes        String?

  @@index([sourceType])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
}

model SourceCoverage {
  id                    String             @id @default(cuid())
  sourceName            String
  sourceType            SourceCoverageType
  baseUrl               String?
  rssUrlsJson           Json?
  enabled               Boolean            @default(true)
  reliabilityScore      Float?
  allowedCategories     String?
  blockedKeywords       String?
  preferredKeywords     String?
  lastCheckedAt         DateTime?
  lastSuccessfulFetchAt DateTime?
  articlesFetchedLastRun Int               @default(0)
  articlesSavedLastRun  Int                @default(0)
  articlesExcludedLastRun Int              @default(0)
  highRelevanceCountLastRun Int            @default(0)
  mediumRelevanceCountLastRun Int          @default(0)
  lowRelevanceCountLastRun Int             @default(0)
  commonExclusionReasons String?
  failuresLast7Days     Int                @default(0)
  sourceReliability     String?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([sourceName, sourceType])
  @@index([sourceType])
  @@index([enabled])
  @@index([lastCheckedAt])
  @@index([lastSuccessfulFetchAt])
}

model MissingDataFlag {
  id          String              @id @default(cuid())
  entityType  String
  entityId    String
  missingField String
  severity    MissingDataSeverity
  reason      String
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  @@index([entityType])
  @@index([entityId])
  @@index([missingField])
  @@index([severity])
  @@index([resolvedAt])
}

model AuditLog {
  id                String   @id @default(cuid())
  entityType        String
  entityId          String
  action            String
  changedByUserId   String?
  changedByEmail    String?
  previousValueJson Json?
  newValueJson      Json?
  reason            String?
  source            String?
  createdAt         DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([changedByUserId])
  @@index([changedByEmail])
  @@index([createdAt])
}

model SavedView {
  id              String              @id @default(cuid())
  name            String
  description     String?
  pageType        String
  filtersJson     Json?
  sortJson        Json?
  columnsJson     Json?
  visibility      SavedViewVisibility @default(private)
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([pageType])
  @@index([visibility])
  @@index([createdByUserId])
  @@index([createdByEmail])
  @@index([createdAt])
}

model TeamNote {
  id                        String   @id @default(cuid())
  entityType                String
  entityId                  String
  note                      String
  tags                      String?
  includeInNextWeeklyReport Boolean  @default(false)
  createdByUserId           String?
  createdByEmail            String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([entityType])
  @@index([entityId])
  @@index([includeInNextWeeklyReport])
  @@index([createdByUserId])
  @@index([createdByEmail])
  @@index([createdAt])
}

model Watchlist {
  id              String              @id @default(cuid())
  name            String
  description     String?
  watchType       WatchlistType
  criteriaJson    Json?
  visibility      SavedViewVisibility @default(private)
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  alerts          Alert[]

  @@index([watchType])
  @@index([visibility])
  @@index([createdByUserId])
  @@index([createdByEmail])
  @@index([createdAt])
}

model Alert {
  id         String              @id @default(cuid())
  watchlistId String?
  watchlist  Watchlist?          @relation(fields: [watchlistId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  alertType  AlertType
  title      String
  message    String
  severity   MissingDataSeverity
  isRead     Boolean             @default(false)
  createdAt  DateTime            @default(now())

  @@index([watchlistId])
  @@index([entityType])
  @@index([entityId])
  @@index([alertType])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
}

model BackfillJob {
  id                String   @id @default(cuid())
  source            String
  year              Int
  month             Int
  keywords          String?
  status            String   @default("queued")
  articlesFound     Int      @default(0)
  articlesSaved     Int      @default(0)
  duplicatesSkipped Int      @default(0)
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  completedAt       DateTime?

  @@index([source])
  @@index([year, month])
  @@index([status])
  @@index([createdAt])
  @@index([completedAt])
}

model Relationship {
  id               String    @id @default(cuid())
  buyerId          String?
  buyer            Buyer?    @relation(fields: [buyerId], references: [id])
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id])
  personId         String?
  person           Person?   @relation(fields: [personId], references: [id])
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id])
  relationshipType String
  sourceUrl        String?
  date             DateTime?
  createdAt        DateTime  @default(now())

  @@index([relationshipType])
  @@index([date])
  @@index([buyerId])
  @@index([companyId])
  @@index([personId])
  @@index([projectId])
}

model WeeklyReport {
  id                String   @id @default(cuid())
  weekStart         DateTime
  weekEnd           DateTime
  title             String
  generatedMarkdown String
  generatedAt       DateTime @default(now())

  @@index([weekStart])
  @@index([generatedAt])
}

model UserProfile {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(viewer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model EmailPreference {
  id                      String   @id @default(cuid())
  userId                  String?
  email                   String   @unique
  receiveWeeklyReport     Boolean  @default(false)
  receiveHighSeverityAlerts Boolean @default(false)
  receiveWatchlistAlerts  Boolean  @default(false)
  weeklyReportDay         String   @default("friday")
  weeklyReportTime        String   @default("09:00")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@index([receiveWeeklyReport])
  @@index([receiveHighSeverityAlerts])
  @@index([receiveWatchlistAlerts])
}

model JobRun {
  id              String       @id @default(cuid())
  jobType         String
  status          JobRunStatus @default(queued)
  startedAt       DateTime?
  completedAt     DateTime?
  createdByUserId String?
  createdByEmail  String?
  inputJson       Json?
  resultJson      Json?
  errorMessage    String?
  lockKey         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([jobType])
  @@index([status])
  @@index([lockKey])
  @@index([createdByUserId])
  @@index([createdByEmail])
  @@index([createdAt])
}

model Feedback {
  id            String           @id @default(cuid())
  userId        String?
  email         String?
  page          String
  entityType    String?
  entityId      String?
  feedbackType  FeedbackType
  message       String
  screenshotUrl String?
  status        FeedbackStatus   @default(new)
  priority      FeedbackPriority @default(medium)
  internalNotes String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([email])
  @@index([page])
  @@index([entityType, entityId])
  @@index([feedbackType])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model UsageEvent {
  id         String   @id @default(cuid())
  userId     String?
  email      String?
  eventType  String
  page       String?
  entityType String?
  entityId   String?
  key        String?
  value      String?
  metadataJson Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([eventType])
  @@index([page])
  @@index([entityType, entityId])
  @@index([key])
  @@index([createdAt])
}
